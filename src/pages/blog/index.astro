---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getPaginatedPosts, getTagsWithCount } from '../../lib/blog';
import { SITE_URL } from '../../config';

const page = Number(Astro.url.searchParams.get('page')) || 1;
const { posts, currentPage, totalPages, hasPrev, hasNext } = await getPaginatedPosts(page, 5);
const tagsWithCount = await getTagsWithCount();
---

<BlogLayout title="Blog" description="Thoughts, tutorials, and insights about web development">
  <div class="blog-container">
    <header class="blog-header">
      <div class="header-top">
        <a href={SITE_URL} class="back-link">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
          </svg>
          <span>Back to Home</span>
        </a>
        
        <a href="/rss.xml" class="rss-link" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
          <span>Subscribe</span>
        </a>
      </div>
      
      <div class="header-content">
        <h1 class="title">Blog</h1>
        <p class="subtitle">Thoughts, tutorials, and insights</p>
      </div>

      <div class="search-container">
        <div class="search-box">
          <svg viewBox="0 0 24 24" fill="currentColor" class="search-icon">
            <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
          </svg>
          <input 
            type="text" 
            id="searchInput"
            placeholder="Search articles..." 
            class="search-input"
            autocomplete="off"
          />
          <button class="search-clear" id="searchClear" aria-label="Clear search">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <div class="blog-content">
      <aside class="blog-sidebar">
        <div class="sidebar-section">
          <h3 class="sidebar-title">
            <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
              <path d="M17.63 5.84C17.27 5.33 16.67 5 16 5L5 5.01C3.9 5.01 3 5.9 3 7v10c0 1.1.9 1.99 2 1.99L16 19c.67 0 1.27-.33 1.63-.84L22 12l-4.37-6.16z"/>
            </svg>
            Tags
          </h3>
          <div class="tags-cloud">
            {tagsWithCount.map(({ tag, count }) => (
              <button class="tag-btn" data-tag={tag} aria-label={`Filter by ${tag}, ${count} posts`}>
                <span class="tag-name">{tag}</span>
                <span class="tag-count">{count}</span>
              </button>
            ))}
          </div>
        </div>

        <div class="sidebar-section">
          <h3 class="sidebar-title">
            <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
            </svg>
            Quick Tips
          </h3>
          <ul class="tips-list">
            <li>Click tags to filter articles</li>
            <li>Use search to find specific topics</li>
            <li>Subscribe via RSS for updates</li>
          </ul>
        </div>
      </aside>

      <main class="main">
        <div class="posts-header">
          <span class="posts-count">
            {posts.length} {posts.length === 1 ? 'article' : 'articles'}
            {currentPage > 1 && ` (Page ${currentPage})`}
          </span>
        </div>

        <div class="posts-list" id="postsList">
          {posts.map((post) => (
            <article class="post-card">
              <a href={`/blog/${post.slug}/`} class="post-card-link">
                <div class="post-content">
                  <div class="post-meta">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('id-ID', {
                        year: 'numeric',
                        month: 'short',
                        day: 'numeric',
                      })}
                    </time>
                    <span class="reading-time">
                      <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
                        <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
                      </svg>
                      {post.data.readingTime} min read
                    </span>
                  </div>
                  <h2 class="post-title">{post.data.title}</h2>
                  <p class="post-description">{post.data.description}</p>
                  <div class="post-tags">
                    {post.data.tags.slice(0, 4).map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                </div>
                <div class="post-footer">
                  <span class="read-more">Read article</span>
                  <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                    <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
                  </svg>
                </div>
              </a>
            </article>
          ))}
        </div>

        {posts.length === 0 && (
          <div class="no-results">
            <div class="no-results-icon">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
              </svg>
            </div>
            <h3>No articles found</h3>
            <p>Try adjusting your search or filter to find what you're looking for.</p>
            <button class="clear-filters" id="clearFilters">Clear all filters</button>
          </div>
        )}

        {totalPages > 1 && (
          <nav class="pagination" aria-label="Blog pagination">
            {hasPrev && (
              <a href={page === 2 ? '/blog' : `/blog?page=${page - 1}`} class="pagination-btn prev">
                <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                  <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
                </svg>
                <span>Previous</span>
              </a>
            )}
            
            <div class="pagination-numbers">
              {Array.from({ length: totalPages }, (_, i) => i + 1).map((num) => (
                <a 
                  href={num === 1 ? '/blog' : `/blog?page=${num}`}
                  class={`pagination-number ${num === currentPage ? 'active' : ''}`}
                  aria-current={num === currentPage ? 'page' : undefined}
                >
                  {num}
                </a>
              ))}
            </div>
            
            {hasNext && (
              <a href={`/blog?page=${page + 1}`} class="pagination-btn next">
                <span>Next</span>
                <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                  <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
                </svg>
              </a>
            )}
          </nav>
        )}
      </main>
    </div>
  </div>

  <!-- Toast Notification -->
  <div class="toast" id="toast" role="alert" aria-live="polite">
    <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
      <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
    </svg>
    <span id="toastMessage">Copied to clipboard!</span>
  </div>

  <script>
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const searchClear = document.getElementById('searchClear') as HTMLElement;
    const postsList = document.getElementById('postsList');
    const tagButtons = document.querySelectorAll('.tag-btn');
    const clearFiltersBtn = document.getElementById('clearFilters');
    const toast = document.getElementById('toast');
    const toastMessage = document.getElementById('toastMessage');
    
    let currentTag: string | null = null;
    let searchTimeout: ReturnType<typeof setTimeout>;

    // Search functionality with debounce
    searchInput?.addEventListener('input', (e) => {
      clearTimeout(searchTimeout);
      const query = (e.target as HTMLInputElement).value;
      
      // Show/hide clear button
      if (searchClear) {
        searchClear.classList.toggle('hidden', !query);
      }
      
      searchTimeout = setTimeout(async () => {
        await filterPosts(query, currentTag);
      }, 300);
    });

    // Clear search
    searchClear?.addEventListener('click', () => {
      if (searchInput) {
        searchInput.value = '';
        searchClear.classList.add('hidden');
        searchInput.focus();
        filterPosts('', currentTag);
      }
    });

    // Tag filter
    tagButtons.forEach((btn) => {
      btn.addEventListener('click', async () => {
        const tag = btn.getAttribute('data-tag');
        
        if (currentTag === tag) {
          currentTag = null;
          btn.classList.remove('active');
        } else {
          currentTag = tag;
          tagButtons.forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
        }
        
        await filterPosts(searchInput?.value || '', currentTag);
      });
    });

    // Clear all filters
    clearFiltersBtn?.addEventListener('click', () => {
      currentTag = null;
      if (searchInput) searchInput.value = '';
      if (searchClear) searchClear.classList.add('hidden');
      tagButtons.forEach((b) => b.classList.remove('active'));
      window.location.href = '/blog';
    });

    async function filterPosts(query: string, tag: string | null) {
      if (!postsList) return;

      // Show loading state
      postsList.classList.add('loading');

      try {
        const params = new URLSearchParams();
        if (query) params.set('q', query);
        if (tag) params.set('tag', tag);
        
        const response = await fetch(`/api/search?${params}`);
        const posts = await response.json();

        postsList.classList.remove('loading');

        if (posts.length === 0) {
          postsList.innerHTML = `
            <div class="no-results">
              <div class="no-results-icon">
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                </svg>
              </div>
              <h3>No articles found</h3>
              <p>Try adjusting your search or filter to find what you're looking for.</p>
              <button class="clear-filters" id="clearFilters">Clear all filters</button>
            </div>
          `;
          
          document.getElementById('clearFilters')?.addEventListener('click', () => {
            window.location.href = '/blog';
          });
        } else {
          postsList.innerHTML = posts.map((post: any) => `
            <article class="post-card">
              <a href="/blog/${post.slug}/" class="post-card-link">
                <div class="post-content">
                  <div class="post-meta">
                    <time datetime="${post.data.pubDate}">${new Date(post.data.pubDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
                    <span class="reading-time">
                      <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
                        <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
                      </svg>
                      ${post.data.readingTime} min read
                    </span>
                  </div>
                  <h2 class="post-title">${post.data.title}</h2>
                  <p class="post-description">${post.data.description}</p>
                  <div class="post-tags">
                    ${post.data.tags.slice(0, 4).map((tag: string) => `<span class="tag">${tag}</span>`).join('')}
                  </div>
                </div>
                <div class="post-footer">
                  <span class="read-more">Read article</span>
                  <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                    <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
                  </svg>
                </div>
              </a>
            </article>
          `).join('');
        }
      } catch (error) {
        console.error('Search error:', error);
        postsList.classList.remove('loading');
      }
    }

    // Show toast notification
    function showToast(message: string) {
      if (!toast || !toastMessage) return;
      
      toastMessage.textContent = message;
      toast.classList.add('show');
      
      setTimeout(() => {
        toast.classList.remove('show');
      }, 3000);
    }
  </script>
</BlogLayout>

<style>
  .blog-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
    position: relative;
    z-index: 10;
  }

  .blog-header {
    margin-bottom: 3rem;
  }

  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .back-link:hover {
    color: var(--emerald-500);
    transform: translateX(-4px);
  }

  .back-link svg {
    width: 20px;
    height: 20px;
  }

  .rss-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--emerald-500);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.625rem 1rem;
    background: rgba(16, 185, 129, 0.1);
    border-radius: 12px;
    border: 1px solid rgba(16, 185, 129, 0.2);
    transition: all 0.3s ease;
  }

  .rss-link:hover {
    background: rgba(16, 185, 129, 0.2);
    border-color: var(--emerald-600);
    transform: translateY(-2px);
  }

  .rss-link svg {
    width: 18px;
    height: 18px;
  }

  .header-content {
    text-align: center;
    margin-bottom: 2rem;
  }

  .title {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, var(--text-primary), var(--emerald-500));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.02em;
  }

  .subtitle {
    color: var(--text-secondary);
    font-size: 1.125rem;
  }

  .search-container {
    max-width: 600px;
    margin: 0 auto;
  }

  .search-box {
    position: relative;
    width: 100%;
  }

  .search-icon {
    position: absolute;
    left: 1.25rem;
    top: 50%;
    transform: translateY(-50%);
    width: 20px;
    height: 20px;
    color: var(--text-muted);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    padding: 1rem 3rem 1rem 3.5rem;
    background: var(--bg-card);
    border: 2px solid var(--border-dark);
    border-radius: 16px;
    color: var(--text-primary);
    font-size: 1rem;
    transition: all 0.3s ease;
  }

  .search-input:focus {
    outline: none;
    border-color: var(--emerald-600);
    box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .search-clear {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    background: var(--bg-card-hover);
    border: none;
    border-radius: 50%;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    opacity: 0;
    visibility: hidden;
  }

  .search-clear:not(.hidden) {
    opacity: 1;
    visibility: visible;
  }

  .search-clear:hover {
    background: var(--emerald-600);
    color: white;
  }

  .search-clear svg {
    width: 16px;
    height: 16px;
  }

  .hidden {
    display: none !important;
  }

  .blog-content {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2rem;
  }

  .blog-sidebar {
    position: sticky;
    top: 2rem;
    height: fit-content;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-section {
    background: var(--bg-card);
    border: 1px solid var(--border-dark);
    border-radius: 16px;
    padding: 1.5rem;
  }

  .sidebar-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .tags-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.875rem;
    background: var(--bg-card-hover);
    border: 1px solid var(--border-dark);
    border-radius: 9999px;
    color: var(--text-secondary);
    font-size: 0.8125rem;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tag-btn:hover {
    border-color: var(--emerald-600);
    color: var(--emerald-400);
    transform: translateY(-2px);
  }

  .tag-btn.active {
    background: rgba(16, 185, 129, 0.15);
    border-color: var(--emerald-600);
    color: var(--emerald-400);
  }

  .tag-name {
    font-weight: 500;
  }

  .tag-count {
    font-size: 0.6875rem;
    color: var(--text-muted);
    background: var(--bg-card);
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
  }

  .tips-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tips-list li {
    padding: 0.75rem 0;
    color: var(--text-secondary);
    font-size: 0.875rem;
    line-height: 1.5;
    border-bottom: 1px solid var(--border-dark);
  }

  .tips-list li:last-child {
    border-bottom: none;
  }

  .tips-list li::before {
    content: '→';
    color: var(--emerald-500);
    margin-right: 0.5rem;
  }

  .main {
    min-width: 0;
  }

  .posts-header {
    margin-bottom: 1.5rem;
  }

  .posts-count {
    color: var(--text-muted);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .posts-list.loading {
    opacity: 0.5;
    pointer-events: none;
  }

  .post-card {
    background: var(--bg-card);
    border: 1px solid var(--border-dark);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .post-card:hover {
    border-color: var(--emerald-600);
    transform: translateY(-4px);
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.4), 0 0 80px rgba(16, 185, 129, 0.15);
  }

  .post-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .post-content {
    padding: 2rem;
  }

  .post-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .reading-time {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .post-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    line-height: 1.3;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .post-description {
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    padding: 0.25rem 0.75rem;
    background: rgba(16, 185, 129, 0.1);
    color: var(--emerald-400);
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2rem;
    border-top: 1px solid var(--border-dark);
  }

  .read-more {
    color: var(--emerald-400);
    font-weight: 600;
    font-size: 0.875rem;
  }

  .post-card:hover .post-footer svg {
    transform: translateX(4px);
  }

  .post-footer svg {
    color: var(--emerald-500);
    transition: transform 0.3s ease;
  }

  .no-results {
    text-align: center;
    padding: 4rem 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border-dark);
    border-radius: 16px;
  }

  .no-results-icon {
    margin-bottom: 1.5rem;
  }

  .no-results-icon svg {
    width: 64px;
    height: 64px;
    color: var(--text-muted);
    opacity: 0.5;
  }

  .no-results h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }

  .no-results p {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  .clear-filters {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--emerald-600);
    border: none;
    border-radius: 12px;
